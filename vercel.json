{
  "buildCommand": "cd claimax-frontend && npm install && npm run build",
  "outputDirectory": "claimax-frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
